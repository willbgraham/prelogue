{
  "expo": {
    "name": "Prelogue",
    "slug": "cast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cast",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E9DFC9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.castapp.cast",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.castapp.cast",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#E9DFC9"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-video",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Prelogue uses the camera so you can record your read for a role.",
          "microphonePermission": "Prelogue uses the microphone to capture your audio while you record your read."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Prelogue needs access to your photos so you can set a profile picture and script posters."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "738e2bd3-6c20-4c4d-9553-44dffa53ed7d"
      }
    },
    "owner": "willg1",
    "updates": {
      "url": "https://u.expo.dev/738e2bd3-6c20-4c4d-9553-44dffa53ed7d"
    }
  }
}
